<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rekap Terang Bulan Juni 2025</title>

<script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#f4f6f9;
    font-family:Arial, Helvetica, sans-serif;
    padding:20px;
}

#laporan{
    max-width:1100px;
    margin:auto;
    background:#fff;
    border-radius:15px;
    padding:25px;
    box-shadow:0 2px 10px rgba(0,0,0,.1);
}

.header{
    text-align:center;
    margin-bottom:25px;
}

.header h1{
    font-size:30px;
    margin-bottom:8px;
}

.header p{
    color:#666;
}

.grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
    align-items:stretch;
}

.box{
    border:1px solid #ddd;
    border-radius:12px;
    overflow:hidden;

    display:flex;
    flex-direction:column;
}

.box h2{
    background:#0d6efd;
    color:white;
    text-align:center;
    padding:12px;
}

.box table{
    width:100%;
    border-collapse:collapse;
    flex-grow:1;
}

th{
    background:#f2f2f2;
}

th,td{
    border:1px solid #ddd;
    padding:8px;
}

td:last-child,
th:last-child{
    text-align:right;
}

.total-row{
    font-weight:bold;
    background:#fafafa;
}

.omzet{
    margin-top:auto;
    padding:12px;
    text-align:center;
    font-weight:bold;
    background:#fafafa;
    border-top:1px solid #ddd;
}

.summary{
    margin-top:25px;
    border:2px solid #0d6efd;
    border-radius:12px;
    overflow:hidden;
}

.summary h2{
    background:#0d6efd;
    color:white;
    text-align:center;
    padding:12px;
}

.summary table{
    width:100%;
    border-collapse:collapse;
}

.summary td{
    padding:12px;
}

.grand-total{
    font-weight:bold;
    font-size:18px;
    background:#f8f9fa;
}

.actions{
    text-align:center;
    margin-top:20px;
}

button{
    padding:12px 20px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    margin:5px;
    color:white;
}

.download{
    background:#198754;
}

.whatsapp{
    background:#25D366;
}

@media(max-width:768px){
    .grid{
        grid-template-columns:1fr;
    }
}
</style>
</head>
<body>

<div id="laporan">

<div class="header">
    <h1>REKAP PENGIRIMAN TERANG BULAN</h1>
    <p>Periode Juni 2025</p>
</div>

<div class="grid">

    <!-- IKHWAN -->
    <div class="box">

        <h2>IKHWAN</h2>

        <table>
            <tr>
                <th>Tanggal</th>
                <th>Kirim</th>
            </tr>

            <tr><td>02 Juni 2025</td><td>34</td></tr>
            <tr><td>04 Juni 2025</td><td>32</td></tr>
            <tr><td>05 Juni 2025</td><td>35</td></tr>
            <tr><td>07 Juni 2025</td><td>23</td></tr>
            <tr><td>08 Juni 2025</td><td>40</td></tr>
            <tr><td>09 Juni 2025</td><td>36</td></tr>
            <tr><td>11 Juni 2025</td><td>40</td></tr>
            <tr><td>12 Juni 2025</td><td>41</td></tr>
            <tr><td>13 Juni 2025</td><td>36</td></tr>
            <tr><td>15 Juni 2025</td><td>30</td></tr>
            <tr><td>16 Juni 2025</td><td>35</td></tr>
            <tr><td>17 Juni 2025</td><td>41</td></tr>

            <tr class="total-row">
                <td>Total Ikhwan</td>
                <td>423</td>
            </tr>
        </table>

        <div class="omzet">
            Omzet Ikhwan : Rp2.749.500
        </div>

    </div>

    <!-- AKHWAT -->
    <div class="box">

        <h2>AKHWAT</h2>

        <table>
            <tr>
                <th>Tanggal</th>
                <th>Kirim</th>
            </tr>

            <tr><td>04 Juni 2025</td><td>30</td></tr>
            <tr><td>05 Juni 2025</td><td>32</td></tr>
            <tr><td>09 Juni 2025</td><td>20</td></tr>
            <tr><td>14 Juni 2025</td><td>28</td></tr>
            <tr><td>15 Juni 2025</td><td>21</td></tr>
            <tr><td>16 Juni 2025</td><td>45</td></tr>

            <tr class="total-row">
                <td>Total Akhwat</td>
                <td>176</td>
            </tr>
        </table>

        <div class="omzet">
            Omzet Akhwat : Rp1.144.000
        </div>

    </div>

</div>

<div class="summary">

    <h2>RINGKASAN KESELURUHAN</h2>

    <table>

        <tr>
            <td>Total Kirim Ikhwan</td>
            <td align="right">423 pcs</td>
        </tr>

        <tr>
            <td>Total Kirim Akhwat</td>
            <td align="right">176 pcs</td>
        </tr>

        <tr>
            <td>Total Kirim</td>
            <td align="right">599 pcs</td>
        </tr>

        <tr>
            <td>Harga per pcs</td>
            <td align="right">Rp6.500</td>
        </tr>

        <tr class="grand-total">
            <td>Total Omzet</td>
            <td align="right">Rp3.893.500</td>
        </tr>

    </table>

</div>

</div>

<div class="actions">
    <button class="download" onclick="downloadPNG()">
        Download PNG
    </button>

    <button class="whatsapp" onclick="kirimWA()">
        Kirim WhatsApp
    </button>
</div>

<script>
function downloadPNG(){
    html2canvas(document.querySelector("#laporan"),{
        scale:2
    }).then(canvas=>{
        const link=document.createElement("a");
        link.download="rekap-terang-bulan-juni-2025.png";
        link.href=canvas.toDataURL("image/png");
        link.click();
    });
}

function kirimWA(){

const pesan =
`*REKAP PENGIRIMAN TERANG BULAN*
Periode Juni 2025

Ikhwan : 423 pcs
Omzet : Rp2.749.500

Akhwat : 176 pcs
Omzet : Rp1.144.000

Total Kirim : 599 pcs
Total Omzet : Rp3.893.500`;

window.open(
`https://wa.me/?text=${encodeURIComponent(pesan)}`,
'_blank'
);

}
</script>

</body>
</html>
